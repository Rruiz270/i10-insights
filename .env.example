# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and never committed.

# Manus AI — image/article generation pipeline
# Get a key at https://manus.im → Settings → API Keys
MANUS_API_KEY=

# Resend — newsletter sending (Phase 3)
# https://resend.com → API Keys
RESEND_API_KEY=

# Neon — Postgres for drafts/articles/subscribers
# Use insights.* schema only; NEVER touch crm.* (shared with BNCC-CAPTACAO)
DATABASE_URL=

# Webhook signing secret for /api/webhooks/manus
# Generate with: openssl rand -hex 32
MANUS_WEBHOOK_SECRET=

# Public site URL (used for OG, sitemap, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://www.institutoi10.com.br
